rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Basic Authentication Checks
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Hardened entity validation
    function isValidJourney(data) {
      return data.keys().hasAll(['id', 'userId', 'createdAt', 'destination', 'params', 'journey'])
        && data.keys().size() == 6
        && data.id is string
        && data.id.size() > 0
        && data.id.size() <= 128
        && data.userId == request.auth.uid
        && data.createdAt is string
        && data.destination is string
        && data.destination.size() > 0
        && data.destination.size() <= 1000
        && data.params is map
        && data.journey is map;
    }

    // Match path for saved journeys
    match /users/{userId}/journeys/{journeyId} {
      allow read, write: if isOwner(userId);
    }
  }
}
